+package com.kuopan.Entity.dto;
+
+import lombok.Getter;
+import lombok.Setter;
+import org.springframework.web.multipart.MultipartFile;
+
+@Getter
+@Setter
+public class UploadFilePropertiesDto {
+
+    private String fileId;
+    private MultipartFile file;
+    private String fileName;
+    private String filePid;
+    private String fileMd5;
+    private Integer chunkIndex;
+    private Integer chunks;
+
+    public UploadFilePropertiesDto(String fileId, MultipartFile file, String fileName, String filePid, String fileMd5, Integer chunkIndex, Integer chunks) {
+        this.fileId = fileId;
+        this.file = file;
+        this.fileName = fileName;
+        this.filePid = filePid;
+        this.fileMd5 = fileMd5;
+        this.chunkIndex = chunkIndex;
+        this.chunks = chunks;
+    }
+}
