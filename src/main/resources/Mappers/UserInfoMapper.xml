<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kuopan.DAO.UserInfoMapper">

    <update id="updateRemainSpaceByGUID">
        update user_info
        <set>
            <if test="occu_space!=null">
                occu_space = occu_space + #{occu_space},
            </if>
            <if test="total_space!=null">
                total_space = total_space + #{total_space},
            </if>
        </set>
        where user_id = #{userId}
        <if test="occu_space!=null">
            and <![CDATA[(occu_space+#{occu_space})<=total_space]]>
        </if>
        <if test="total_space!=null">
            and <![CDATA[total_space+#{occu_space}>=occu_space]]>
        </if>

    </update>

</mapper>
